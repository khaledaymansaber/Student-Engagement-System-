@model StudentEngagementSystem.ViewModels.Dashboard.DashboardViewModel
@using Microsoft.AspNetCore.Identity
@using StudentEngagementSystem.Models
@inject UserManager<Teacher> UserManager
@{
    ViewData["Title"] = "Dashboard Overview";
    var teacherUser = await UserManager.GetUserAsync(User);
    var displayName = teacherUser?.FullName ?? User.Identity?.Name ?? "User";
    if (displayName.Contains("@"))
    {
        displayName = displayName.Split('@')[0];
        if (displayName.Length > 0)
        {
            displayName = char.ToUpper(displayName[0]) + displayName.Substring(1);
        }
    }
}

<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">
    <div>
        <h2 class="text-2xl font-bold text-gray-800">Welcome back, Mr. @displayName! 👋</h2>
        <p class="text-gray-500 text-sm mt-1">Here is what's happening with your students today.</p>
    </div>
</div>

<div class="mb-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Card 1: Total Videos Processed -->
        <div class="bg-white rounded-2xl shadow-sm hover:-translate-y-1 hover:shadow-md transition-all duration-300 p-6 border border-gray-100 relative overflow-hidden group">
            <div class="absolute -right-6 -top-6 w-24 h-24 bg-brand-50 rounded-full opacity-50 group-hover:scale-110 transition-transform"></div>
            <div class="relative z-10 flex justify-between items-start mb-4">
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider font-sans">Total Videos Processed</span>
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-brand-600 flex items-center justify-center text-white shadow-md">
                    <i class="fa-solid fa-video text-lg"></i>
                </div>
            </div>
            <h2 class="relative z-10 text-4xl font-extrabold text-gray-900">@Model.TotalVideos</h2>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Recent Students Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 flex flex-col h-full">
        <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50 rounded-t-2xl">
            <h5 class="font-bold text-gray-800 text-lg">Recent Students</h5>
            <a asp-controller="Students" asp-action="Index" class="text-sm font-semibold text-brand-600 hover:text-brand-700 bg-brand-50 hover:bg-brand-100 px-3 py-1.5 rounded-lg transition-colors">View All</a>
        </div>
        <div class="p-0 flex-1">
            @if (!Model.RecentStudents.Any())
            {
                <div class="p-8 text-center">
                    <p class="text-gray-500">No students found. <a asp-controller="Students" asp-action="Create" class="text-brand-600 font-medium hover:underline">Add a student</a> to get started.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <tbody>
                            @foreach (var student in Model.RecentStudents)
                            {
                                <tr class="hover:bg-gray-50 border-b border-gray-50 transition-colors last:border-0">
                                    <td class="p-4 w-16">
                                        @if (!string.IsNullOrEmpty(student.Photo))
                                        {
                                            <img src="~/uploads/photos/@student.Photo" class="w-10 h-10 rounded-full object-cover shadow-sm" alt="@student.FullName" />
                                        }
                                        else
                                        {
                                            <div class="w-10 h-10 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center font-bold shadow-sm">
                                                @student.FullName.Substring(0, 1).ToUpper()
                                            </div>
                                        }
                                    </td>
                                    <td class="p-4">
                                        <h6 class="font-bold text-gray-900 mb-0.5">@student.FullName</h6>
                                        <p class="text-xs text-gray-500 font-medium">ID: @student.StudentCode</p>
                                    </td>
                                    <td class="p-4 text-right">
                                        <a asp-controller="Students" asp-action="Details" asp-route-id="@student.StudentId" class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-50 hover:bg-brand-50 text-gray-400 hover:text-brand-600 transition-colors">
                                            <i class="fa-solid fa-chevron-right text-sm"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
    
    <!-- Recent Uploads Card -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 flex flex-col h-full">
        <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50 rounded-t-2xl">
            <h5 class="font-bold text-gray-800 text-lg">Recent Uploads</h5>
        </div>
        <div class="p-0 flex-1">
            @if (!Model.RecentVideos.Any())
            {
                <div class="p-8 text-center">
                    <p class="text-gray-500">No videos uploaded yet.</p>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <tbody>
                            @foreach (var video in Model.RecentVideos)
                            {
                                <tr class="hover:bg-gray-50 border-b border-gray-50 transition-colors last:border-0">
                                    <td class="p-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-lg bg-orange-50 text-orange-500 flex items-center justify-center text-lg shrink-0">
                                                <i class="fa-solid fa-file-video"></i>
                                            </div>
                                            <div class="min-w-0">
                                                <h6 class="font-bold text-gray-900 mb-0.5 truncate max-wxs">@video.VideoName</h6>
                                                <p class="text-xs text-gray-500 font-medium truncate">@video.Student?.FullName • @video.UploadDate.ToString("MMM dd, yyyy")</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-4 text-right">
                                        @if (video.AnalysisResult != null)
                                        {
                                            <a asp-controller="Analysis" asp-action="Details" asp-route-videoId="@video.VideoId" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-50 text-emerald-700 text-xs font-bold hover:bg-emerald-100 transition-colors">
                                                <i class="fa-solid fa-chart-line"></i> Analyzed
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-xs font-bold">
                                                Pending
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
