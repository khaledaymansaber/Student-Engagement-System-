@model StudentEngagementSystem.ViewModels.Videos.VideoUploadViewModel
@{
    ViewData["Title"] = "Upload Video";
}

<div class="max-w-2xl mx-auto mt-8">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        
        <div class="px-8 py-6 border-b border-gray-100 bg-gray-50/50 flex items-center justify-between">
            <div>
                <h2 class="text-lg font-bold text-gray-900">Upload Video</h2>
                <p class="text-sm font-medium text-gray-500 mt-1">For student: <span class="text-brand-600 font-semibold">@Model.StudentName</span></p>
            </div>
            <div class="w-12 h-12 bg-brand-100 text-brand-600 rounded-full flex items-center justify-center text-xl shadow-inner">
                <i class="fa-solid fa-cloud-arrow-up"></i>
            </div>
        </div>

        <div class="p-8">
            <form asp-action="Upload" enctype="multipart/form-data" id="uploadForm">
                <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-medium mb-6 bg-rose-50 p-4 rounded-xl border border-rose-100"></div>
                <input type="hidden" asp-for="StudentId" />
                
                <div class="mb-6">
                    <label asp-for="VideoName" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                    <input asp-for="VideoName" class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 transition-colors text-gray-900" placeholder="e.g. Math Lecture 1 - Group Project" />
                    <span asp-validation-for="VideoName" class="text-rose-500 text-xs font-medium mt-1.5 block"></span>
                </div>

                <div class="mb-8">
                    <label asp-for="VideoFile" class="block text-sm font-semibold text-gray-700 mb-2"></label>
                    <div class="relative group cursor-pointer" onclick="document.getElementById('videoFileInput').click();">
                        <div class="absolute inset-0 bg-brand-50 rounded-2xl border-2 border-dashed border-brand-200 group-hover:bg-brand-100 group-hover:border-brand-400 transition-colors"></div>
                        <div class="relative p-10 flex flex-col items-center justify-center text-center z-10">
                            <div class="w-16 h-16 mb-4 rounded-full bg-white flex items-center justify-center shadow-sm text-brand-500 group-hover:scale-110 transition-transform">
                                <i class="fa-solid fa-file-video text-2xl"></i>
                            </div>
                            <h5 class="text-lg font-bold text-gray-900 mb-1">Click to select video</h5>
                            <p class="text-sm font-medium text-gray-500">MP4, AVI, or MOV up to 500MB</p>
                        </div>
                        <input asp-for="VideoFile" type="file" id="videoFileInput" class="hidden" accept=".mp4,.avi,.mov" onchange="updateFileName(this)" />
                    </div>
                    
                    <div id="selectedFileName" class="mt-4 p-4 bg-emerald-50 border border-emerald-100 rounded-xl flex items-center gap-3" style="display:none;">
                        <i class="fa-solid fa-circle-check text-emerald-500 text-lg"></i>
                        <span id="fileNameText" class="text-sm font-bold text-emerald-800 truncate"></span>
                    </div>
                    <span asp-validation-for="VideoFile" class="text-rose-500 text-xs font-medium mt-1.5 block"></span>
                </div>
                
                <!-- Loading Overlay -->
                <div id="loadingOverlay" style="display:none;" class="my-6 p-8 bg-brand-50 border border-brand-100 rounded-2xl text-center">
                    <div class="inline-block animate-spin w-10 h-10 border-4 border-brand-200 border-t-brand-600 rounded-full mb-4"></div>
                    <h5 class="text-lg font-bold text-brand-900 mb-2">Uploading & Analyzing AI...</h5>
                    <p class="text-sm font-medium text-brand-700/80 max-w-sm mx-auto">Please do not close this page. This may take a few moments depending on the video length.</p>
                </div>

                <div class="flex items-center gap-3 pt-4 border-t border-gray-100" id="actionButtons">
                    <button type="submit" class="px-6 py-2.5 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-xl shadow-sm transition-colors flex items-center gap-2">
                        <i class="fa-solid fa-wand-magic-sparkles"></i> Upload & Analyze
                    </button>
                    <a asp-controller="Students" asp-action="Details" asp-route-id="@Model.StudentId" class="px-6 py-2.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 font-semibold rounded-xl transition-colors">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function updateFileName(input) {
            if (input.files && input.files[0]) {
                var fileName = input.files[0].name;
                document.getElementById('fileNameText').innerText = "Selected file: " + fileName;
                document.getElementById('selectedFileName').style.display = 'flex';
            } else {
                document.getElementById('selectedFileName').style.display = 'none';
            }
        }

        document.getElementById('uploadForm').addEventListener('submit', function(e) {
            var isValid = $(this).valid();
            if (isValid) {
                document.getElementById('actionButtons').style.display = 'none';
                document.getElementById('loadingOverlay').style.display = 'block';
            }
        });
    </script>
}
