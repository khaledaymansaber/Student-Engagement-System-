@model StudentEngagementSystem.ViewModels.Students.StudentCreateViewModel
@{
    ViewData["Title"] = "Add Student";
}

<div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 flex flex-col mb-4 overflow-hidden">
        <!-- Header -->
        <div class="px-6 py-5 border-b border-gray-100 flex items-center bg-gray-50/50">
            <div class="w-10 h-10 rounded-full bg-brand-100 text-brand-600 flex items-center justify-center mr-4">
                <i class="fa-solid fa-user-plus text-lg"></i>
            </div>
            <div>
                <h5 class="font-bold text-gray-900 text-lg">Student Information</h5>
                <p class="text-xs text-gray-500 mt-0.5">Enter the student's details to enroll them in the system.</p>
            </div>
        </div>

        <!-- Form -->
        <div class="p-6">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="bg-red-50 text-red-600 p-4 rounded-xl mb-6 text-sm font-medium"></div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="FullName" class="block text-sm font-semibold text-gray-700 mb-1.5"></label>
                        <input asp-for="FullName" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all text-gray-800" placeholder="e.g. John Doe" />
                        <span asp-validation-for="FullName" class="text-red-500 text-xs font-medium mt-1 block"></span>
                    </div>
                    
                    <div>
                        <label asp-for="StudentCode" class="block text-sm font-semibold text-gray-700 mb-1.5"></label>
                        <input asp-for="StudentCode" class="w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-xl focus:bg-white focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all text-gray-800" placeholder="e.g. STU-1001" />
                        <span asp-validation-for="StudentCode" class="text-red-500 text-xs font-medium mt-1 block"></span>
                    </div>
                    
                    <div class="md:col-span-2 mt-2">
                        <label asp-for="PhotoFile" class="block text-sm font-semibold text-gray-700 mb-1.5"></label>
                        <div class="flex items-center">
                            <input asp-for="PhotoFile" class="block w-full text-sm text-gray-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100 transition-colors border border-gray-200 rounded-xl bg-gray-50 cursor-pointer focus:outline-none" accept="image/*" />
                        </div>
                        <p class="text-xs text-gray-500 mt-2"><i class="fa-solid fa-circle-info mr-1"></i> Optional. Accepted formats: JPG, PNG, GIF.</p>
                    </div>
                </div>
                
                <div class="mt-8 pt-6 border-t border-gray-100 flex items-center justify-end gap-3">
                    <a asp-action="Index" class="px-5 py-2.5 text-sm font-semibold text-gray-600 bg-white border border-gray-300 rounded-xl hover:bg-gray-50 transition-colors">Cancel</a>
                    <button type="submit" class="px-5 py-2.5 text-sm font-semibold text-white bg-brand-600 rounded-xl hover:bg-brand-700 shadow-sm transition-colors">Save Student</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
