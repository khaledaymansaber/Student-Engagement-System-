@model StudentEngagementSystem.ViewModels.Students.StudentDetailsViewModel
@{
    ViewData["Title"] = "Student Profile";
}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Left Column: Student Info -->
    <div class="lg:col-span-1">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 flex flex-col h-full overflow-hidden">
            <!-- Header Accent -->
            <div class="h-24 bg-gradient-to-r from-brand-500 to-brand-600"></div>
            
            <div class="px-6 pb-6 text-center -mt-12 relative">
                @if (!string.IsNullOrEmpty(Model.Photo))
                {
                    <img src="~/uploads/photos/@Model.Photo" class="w-24 h-24 rounded-full object-cover shadow-md mx-auto border-4 border-white bg-white" alt="@Model.FullName" />
                }
                else
                {
                    <div class="w-24 h-24 rounded-full bg-brand-100 text-brand-700 flex items-center justify-center font-bold text-3xl shadow-md mx-auto border-4 border-white">
                        @Model.FullName.Substring(0, 1).ToUpper()
                    </div>
                }
                
                <h4 class="font-bold text-xl text-gray-900 mt-4">@Model.FullName</h4>
                <p class="text-sm font-medium text-gray-500 mb-6">ID: @Model.StudentCode</p>
                
                <div class="border-t border-gray-100 pt-6">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-sm font-medium text-gray-500">Total Videos</span>
                        <span class="px-2.5 py-1 bg-brand-50 text-brand-700 rounded-lg text-sm font-bold">@Model.Videos.Count()</span>
                    </div>
                    <div class="flex justify-between items-center mb-6">
                        <span class="text-sm font-medium text-gray-500">Added On</span>
                        <span class="text-sm font-bold text-gray-900">@Model.CreatedDate.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
                
                <div class="space-y-3 mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.StudentId" class="flex items-center justify-center w-full px-4 py-2.5 bg-white border border-gray-300 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition-colors shadow-sm">
                        <i class="fa-solid fa-pen text-sm mr-2 text-gray-400"></i> Edit Profile
                    </a>
                    <a asp-controller="Videos" asp-action="Upload" asp-route-studentId="@Model.StudentId" class="flex items-center justify-center w-full px-4 py-2.5 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors shadow-sm">
                        <i class="fa-solid fa-cloud-arrow-up text-sm mr-2"></i> Upload Video
                    </a>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Right Column: Videos List -->
    <div class="lg:col-span-2">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 h-full flex flex-col">
            <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between bg-gray-50/50 rounded-t-2xl">
                <h5 class="font-bold text-gray-800 text-lg">Uploaded Videos</h5>
            </div>
            
            <div class="p-6 flex-1">
                @if (!Model.Videos.Any())
                {
                    <div class="text-center py-12">
                        <div class="w-16 h-16 bg-gray-50 text-gray-400 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                            <i class="fa-solid fa-video-slash"></i>
                        </div>
                        <h5 class="text-xl font-bold text-gray-900 mb-2">No videos yet</h5>
                        <p class="text-gray-500 max-w-sm mx-auto mb-6">Upload a video for this student to get AI engagement analysis.</p>
                        <a asp-controller="Videos" asp-action="Upload" asp-route-studentId="@Model.StudentId" class="inline-flex items-center justify-center px-5 py-2.5 bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold rounded-xl shadow-sm transition-colors">
                            Upload Now
                        </a>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        @foreach (var video in Model.Videos)
                        {
                            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 flex flex-col hover:border-brand-300 hover:shadow-md transition-all group">
                                <div class="flex justify-between items-start mb-4">
                                    <div class="flex items-center gap-3 overflow-hidden">
                                        <div class="w-10 h-10 rounded-lg bg-white border border-gray-200 text-brand-600 flex items-center justify-center shrink-0">
                                            <i class="fa-solid fa-file-video"></i>
                                        </div>
                                        <div class="min-w-0">
                                            <h6 class="font-bold text-gray-900 text-sm truncate" title="@video.VideoName">@video.VideoName</h6>
                                            <p class="text-xs font-medium text-gray-500">@video.UploadDate.ToString("MMM dd, yyyy")</p>
                                        </div>
                                    </div>
                                    
                                    <!-- Action Buttons -->
                                    <div class="flex items-center gap-1 opacity-100 sm:opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
                                        <a asp-controller="Videos" asp-action="Download" asp-route-id="@video.VideoId" class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-500 hover:bg-gray-200 hover:text-gray-800 transition-colors" title="Download">
                                            <i class="fa-solid fa-download text-sm"></i>
                                        </a>
                                        <form asp-controller="Videos" asp-action="Delete" asp-route-id="@video.VideoId" method="post" class="inline" onsubmit="return confirm('Are you sure you want to delete this video?');">
                                            <button type="submit" class="w-8 h-8 flex items-center justify-center rounded-lg text-red-400 hover:bg-red-100 hover:text-red-600 transition-colors" title="Delete">
                                                <i class="fa-solid fa-trash text-sm"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                
                                <div class="mt-auto">
                                    @if (video.AnalysisResult != null)
                                    {
                                        <a asp-controller="Analysis" asp-action="Details" asp-route-videoId="@video.VideoId" class="flex items-center justify-center w-full px-3 py-2 bg-emerald-50 text-emerald-700 font-semibold text-sm rounded-lg hover:bg-emerald-100 transition-colors border border-emerald-100">
                                            <i class="fa-solid fa-chart-line mr-2"></i> View Analysis
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="flex items-center justify-center w-full px-3 py-2 bg-gray-200 text-gray-500 font-semibold text-sm rounded-lg cursor-not-allowed border border-gray-200" disabled>
                                            <i class="fa-solid fa-hourglass-half mr-2"></i> Processing...
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
