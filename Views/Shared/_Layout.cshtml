@using Microsoft.AspNetCore.Identity
@using StudentEngagementSystem.Models
@inject UserManager<Teacher> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SEM System</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Inter Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Alpine.js for dropdowns -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: { sans: ['Inter', 'sans-serif'] },
            colors: {
              brand: {
                50: '#eff6ff',
                100: '#dbeafe',
                500: '#3b82f6',
                600: '#2563eb',
                900: '#1e3a8a',
              }
            }
          }
        }
      }
    </script>
    <style>
        /* Smooth transitions */
        .sidebar-transition { transition: all 0.3s ease; }
    </style>
</head>
<body class="bg-gray-50 font-sans text-gray-800 antialiased h-screen overflow-hidden flex selection:bg-brand-500 selection:text-white">

    <!-- Sidebar -->
    <aside class="w-64 bg-gray-900 text-white flex flex-col sidebar-transition shrink-0 z-20">
        <!-- Logo -->
        <div class="h-16 flex items-center px-6 border-b border-gray-800 bg-gray-900 shadow-sm relative z-10">
            <div class="w-8 h-8 rounded bg-brand-500 flex items-center justify-center text-white me-3 shadow-lg">
                <i class="fa-solid fa-graduation-cap"></i>
            </div>
            <span class="text-xl font-bold tracking-tight text-white">SEM System</span>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 overflow-y-auto py-6 px-3 space-y-1 scrollbar-hide">
            <div class="px-3 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">
                Core Modules
            </div>
            <a asp-controller="Dashboard" asp-action="Index" 
               class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "bg-gray-800 text-white" : "text-gray-300 hover:bg-gray-800 hover:text-white")">
                <i class="fa-solid fa-chart-line w-6 text-center text-lg @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "text-brand-500" : "text-gray-400 group-hover:text-white")"></i>
                <span class="ml-2">Dashboard</span>
            </a>

            <a asp-controller="Students" asp-action="Index" 
               class="group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Students" ? "bg-gray-800 text-white" : "text-gray-300 hover:bg-gray-800 hover:text-white")">
                <i class="fa-solid fa-users w-6 text-center text-lg @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Students" ? "text-brand-500" : "text-gray-400 group-hover:text-white")"></i>
                <span class="ml-2">Students</span>
            </a>
            
            <div class="px-3 mt-8 mb-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">
                System
            </div>
            <!-- Logout Button in Sidebar for convenience -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form asp-controller="Account" asp-action="Logout" method="post" class="w-full">
                    <button type="submit" class="w-full group flex items-center px-3 py-2.5 text-sm font-medium rounded-lg text-gray-300 hover:bg-red-500/10 hover:text-red-400 transition-colors">
                        <i class="fa-solid fa-sign-out-alt w-6 text-center text-lg text-gray-400 group-hover:text-red-400"></i>
                        <span class="ml-2">Logout</span>
                    </button>
                </form>
            }
        </nav>
        
        <!-- User Profile snippet at bottom of sidebar -->
        @if (User.Identity?.IsAuthenticated == true)
        {
            var teacherUser = await UserManager.GetUserAsync(User);
            var displayName = teacherUser?.FullName ?? User.Identity?.Name ?? "User";
            if (displayName.Contains("@"))
            {
                displayName = displayName.Split('@')[0];
                if (displayName.Length > 0)
                {
                    displayName = char.ToUpper(displayName[0]) + displayName.Substring(1);
                }
            }
            <div class="p-4 border-t border-gray-800 bg-gray-900/50">
                <div class="flex items-center">
                    <div class="w-9 h-9 rounded-full bg-brand-600 flex items-center justify-center text-white font-bold shadow-inner">
                        @(displayName.Length > 0 ? displayName.Substring(0, 1).ToUpper() : "U")
                    </div>
                    <div class="ml-3 truncate">
                        <p class="text-sm font-medium text-white truncate">@displayName</p>
                        <p class="text-xs text-gray-400">Administrator</p>
                    </div>
                </div>
            </div>
        }
    </aside>

    <!-- Main Content Wrapper -->
    <div class="flex-1 flex flex-col overflow-hidden bg-gray-50 relative">
        <!-- Top Header -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-6 z-10 shadow-sm">
            <!-- Left Side: Title / Breadcrumbs -->
            <div class="flex items-center">
                <h1 class="text-2xl font-bold text-gray-800">@ViewData["Title"]</h1>
            </div>

            <!-- Right Side: Profile / Actions -->
            <div class="flex items-center space-x-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    @await Component.InvokeAsync("Notifications")
                }
            </div>
        </header>

        <!-- Main Scrollable Area -->
        <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50/50 p-6">
            <div class="max-w-7xl mx-auto">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center text-emerald-800 shadow-sm">
                        <i class="fa-solid fa-check-circle text-emerald-500 text-xl mr-3"></i>
                        <span class="font-medium">@TempData["SuccessMessage"]</span>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-100 flex items-center text-red-800 shadow-sm">
                        <i class="fa-solid fa-exclamation-circle text-red-500 text-xl mr-3"></i>
                        <span class="font-medium">@TempData["ErrorMessage"]</span>
                    </div>
                }

                <!-- Page Content Injected Here -->
                @RenderBody()
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
